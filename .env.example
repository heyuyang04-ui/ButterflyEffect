# ============================================================
# 多视角决策辅助系统 —— 环境配置
# ------------------------------------------------------------
# 复制为 .env 后填写。
# 每一组（DEEPSEEK / DEEPSEEK_R1 / OPENAI / KIMI ...）就是一个"预设"
# 在 config.yaml 里通过 preset 名引用。你可以自己加新组，按相同
# 命名规则即可：{NAME}_API_KEY / {NAME}_BASE_URL / {NAME}_MODEL / {NAME}_PROTOCOL
#
# PROTOCOL 取值：openai（OpenAI 兼容协议）| anthropic（Claude 原生 SDK）
# 只填你实际要用的那几组即可，其他可留空。
# ============================================================

# ---- DeepSeek 普通对话模型 ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_PROTOCOL=openai

# ---- DeepSeek R1 推理模型（适合算命/解卦/深度推理）----
DEEPSEEK_R1_API_KEY=
DEEPSEEK_R1_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_R1_MODEL=deepseek-reasoner
DEEPSEEK_R1_PROTOCOL=openai

# ---- OpenAI（或任意 OpenAI 兼容的中转）----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROTOCOL=openai

# ---- 通义千问（DashScope OpenAI 兼容模式）----
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_PROTOCOL=openai

# ---- Kimi / Moonshot ----
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k
KIMI_PROTOCOL=openai

# ---- Anthropic Claude（原生 SDK，不走 base_url）----
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_PROTOCOL=anthropic

# ---- Ollama 本地（无需 key）----
OLLAMA_API_KEY=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_PROTOCOL=openai
